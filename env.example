# HubSpot — one form per programme (new website forms, not legacy embeds)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_REGION=na2
NEXT_PUBLIC_HUBSPOT_FORM_PGP=
NEXT_PUBLIC_HUBSPOT_FORM_AI_MARKETING=
NEXT_PUBLIC_HUBSPOT_FORM_UG=

# Production site URL — used for HubSpot pageUri (avoids localhost spam) and canonical links
NEXT_PUBLIC_SITE_URL=https://www.hiveschool.co

# Cloudflare R2 — public media CDN for videos (images stay on Vercel)
# Required in Vercel — videos are NOT stored in the git repo.
NEXT_PUBLIC_MEDIA_CDN_URL=https://pub-760fa3db0e0e491da59597144b40ce1f.r2.dev

# S3 API (upload only) — endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Dashboard may show: ...r2.cloudflarestorage.com/hiveschool — bucket name is separate.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=hiveschool

# R2 → Manage R2 API Tokens → Object Read & Write (local only — never commit)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Google — GTM loads GA4 / Google Ads tags (configure inside GTM UI)
NEXT_PUBLIC_GTM_ID=

# GA4 server-side lead events (Measurement Protocol — no gtag.js required for leads)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Meta Conversions API only — NO Meta Pixel script on the site
# META_PIXEL_ID = your data source ID in Events Manager (used by CAPI, not a browser pixel install)
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional — remove after testing in Events Manager → Test events
META_CAPI_TEST_EVENT_CODE=
